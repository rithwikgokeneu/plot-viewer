# Vercel Postgres / Neon
# NOTE: the Neon integration marks these SENSITIVE, so `vercel env pull` writes
# them EMPTY. At runtime on Vercel they inject automatically. For LOCAL dev, paste
# the pooled connection string here by hand (host contains "-pooler"; append
# ?sslmode=require). `@vercel/postgres` reads POSTGRES_URL.
POSTGRES_URL=

# Vercel Blob — created by connecting the Blob store to the project (not sensitive).
BLOB_READ_WRITE_TOKEN=

# Single-operator admin auth (server-only — do NOT prefix with NEXT_PUBLIC_)
ADMIN_PASSWORD=change-me
# 32+ random bytes: `openssl rand -hex 32`
AUTH_SECRET=
